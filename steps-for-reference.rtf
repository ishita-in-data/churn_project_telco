\f2\b0\fs26 \cf0 from sklearn.model_selection import GridSearchCV\
from xgboost import XGBClassifier\
\
# Define parameter grid\
param_grid = \{\
    'n_estimators': [50, 100, 150],\
    'max_depth': [4, 6, 8],\
    'learning_rate': [0.01, 0.05, 0.1],\
    'subsample': [0.7, 0.9, 1.0],\
    'colsample_bytree': [0.7, 0.9, 1.0]\
\}\
\
# Initialize base model\
xgb_base = XGBClassifier(random_state=42, n_jobs=-1)\
\
# Grid search (3 \'d7 3 \'d7 3 \'d7 3 \'d7 3 = 243 combinations!)\
grid_search = GridSearchCV(\
    xgb_base,\
    param_grid,\
    cv=5,  # 5-fold CV\
    scoring='roc_auc',  # Optimize for ROC-AUC\
    n_jobs=-1,  # Use all CPU cores\
    verbose=1\
)\
\
# Fit (this will take a few minutes!)\
print("Starting GridSearchCV... (this may take 5-10 minutes)")\
grid_search.fit(X_train, y_train)\
\
print(f"\\nBest parameters: \{grid_search.best_params_\}")\
print(f"Best CV ROC-AUC: \{grid_search.best_score_:.4f\}")\
\
