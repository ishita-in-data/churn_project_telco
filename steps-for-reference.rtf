X_train_poly = poly.fit_transform(X_train[['tenure', 'monthlyCharges']])\
\
# Creates: tenure, monthlyCharges, tenure^2, monthlyCharges^2, tenure*monthlyCharges\
\pard\pardeftab720\sa319\partightenfactor0

\f0\b\fs24 \cf0 D) Log Transformations (for skewed features)\
\pard\pardeftab720\partightenfactor0

\f2\b0\fs26 \cf0 # If totalCharges is right-skewed\
X_train['log_totalCharges'] = np.log1p(X_train['totalCharges'])  # log1p handles 0s\
\
X_test['log_totalCharges'] = np.log1p(X_test['totalCharges'])\
\pard\pardeftab720\sa319\partightenfactor0

\f0\b\fs24 \cf0 E) Domain-Specific Features\
\pard\pardeftab720\partightenfactor0

\f2\b0\fs26 \cf0 # Customer value: high tenure + high spending = loyal, won't churn\
X_train['customer_value'] = (X_train['tenure'] / X_train['tenure'].max()) * \\\
                             (X_train['totalCharges'] / X_train['totalCharges'].max())\
\
X_test['customer_value'] = (X_test['tenure'] / X_test['tenure'].max()) * \\\
                            (X_test['totalCharges'] / X_test['totalCharges'].max())\
\
# Recent spending trend\
X_train['recent_spending_increase'] = (X_train['monthlyCharges'] > X_train['avgMonthlyCharges']).astype(int)\
\
X_test['recent_spending_increase'] = (X_test['monthlyCharges'] > X_test['avgMonthlyCharges']).astype(int)\
\pard\pardeftab720\sa280\partightenfactor0

