\f0\b\fs28 \cf0 Outlier detection methods:\
\pard\pardeftab720\sa319\partightenfactor0

\fs24 \cf0 A) IQR Method (Interquartile Range)\
\pard\pardeftab720\partightenfactor0

\f2\b0\fs26 \cf0 def find_outliers_iqr(data, column):\
    Q1 = data[column].quantile(0.25)\
    Q3 = data[column].quantile(0.75)\
    IQR = Q3 - Q1\
\
    lower_bound = Q1 - 1.5 * IQR\
    upper_bound = Q3 + 1.5 * IQR\
\
    outliers = data[(data[column] < lower_bound) | (data[column] > upper_bound)]\
    return outliers\
\
# Find outliers in tenure\
outliers = find_outliers_iqr(df, 'tenure')\
print(f"Outliers in tenure: \{len(outliers)\}")\
\pard\pardeftab720\sa319\partightenfactor0

\f0\b\fs24 \cf0 B) Z-Score Method\
\pard\pardeftab720\partightenfactor0

\f2\b0\fs26 \cf0 from scipy import stats\
\
# Calculate Z-score\
z_scores = np.abs(stats.zscore(df['monthlyCharges']))\
\
# Identify outliers (|z| > 3)\
outliers = df[z_scores > 3]\
print(f"Outliers in monthlyCharges: \{len(outliers)\}")\
\pard\pardeftab720\sa280\partightenfactor0

\f0\b\fs28 \cf0 Decision: Remove or Keep?\
