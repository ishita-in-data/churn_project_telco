\f2\b0\fs26 \cf0 # Key hyperparameters:\
\
# 1. n_estimators: Number of trees\
#    - Higher = better accuracy (but slower, overfitting risk)\
#    - Typical: 50-200\
\
# 2. max_depth: Tree depth\
#    - Higher = captures complex patterns (but overfitting)\
#    - Typical: 3-10\
\
# 3. learning_rate: How fast model learns\
#    - Higher = faster learning (but overfitting)\
#    - Lower = slower but steadier\
#    - Typical: 0.01-0.3\
\
# 4. subsample: Fraction of samples per tree\
#    - Lower = more regularization (less overfitting)\
#    - Typical: 0.5-1.0\
\
# 5. colsample_bytree: Fraction of features per tree\
#    - Lower = more regularization\
#    - Typical: 0.5-1.0\
\
# 6. reg_alpha: L1 regularization\
#    - Higher = more regularization (simpler model)\
#    - Typical: 0-1\
\
# 7. reg_lambda: L2 regularization\
#    - Higher = more regularization\
#    - Typical: 0-1\
\pard\pardeftab720\partightenfactor0

