            xticklabels=['No Churn', 'Churn'],\
            yticklabels=['No Churn', 'Churn'])\
plt.ylabel('True Label')\
plt.xlabel('Predicted Label')\
plt.title('Confusion Matrix - XGBoost')\
plt.show()\
\
# Output:\
#           Predicted\
#        No Churn  Churn\
# Actual\
# No Churn   1050    60\
# Churn       159    140\
