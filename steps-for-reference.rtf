\f2\fs26 \cf0 # src/predict.py\
import joblib\
import json\
import numpy as np\
import pandas as pd\
from sklearn.preprocessing import StandardScaler\
\
class ChurnPredictor:\
    def __init__(self, model_path, metadata_path, scaler_path):\
        """Load model, metadata, and scaler"""\
        self.model = joblib.load(model_path)\
        with open(metadata_path, 'r') as f:\
            self.metadata = json.load(f)\
        self.scaler = joblib.load(scaler_path)\
        self.feature_columns = self.metadata['feature_columns']\
\
    def predict(self, input_dict):\
        """\
        Input: dict with feature names as keys\
        Output: prediction (0/1) + probability of churn\
        """\
        # Convert to DataFrame\
        df = pd.DataFrame([input_dict])\
\
        # Ensure all features present and in correct order\
        df = df[self.feature_columns]\
\
        # Scale\
        df_scaled = self.scaler.transform(df)\
\
        # Predict\
        prediction = self.model.predict(df_scaled)[0]\
        probability = self.model.predict_proba(df_scaled)[0][1]\
\
        return \{\
            'prediction': int(prediction),  # 0 or 1\
            'churn_probability': float(probability),\
            'no_churn_probability': float(1 - probability)\
        \}\
\
    def get_feature_importance(self, top_n=10):\
        """Get top N important features"""\
        importances = self.model.feature_importances_\
        indices = np.argsort(importances)[::-1][:top_n]\
\
        return \{\
            self.feature_columns[i]: float(importances[i])\
            for i in indices\
        \}\
\
# Example usage:\
if __name__ == "__main__":\
    predictor = ChurnPredictor(\
        'models/churn_xgboost_model.pkl',\
        'models/feature_metadata.json',\
        'models/scaler.pkl'\
    )\
\
    # Test prediction\
    test_input = \{\
        'Age': 35,\
        'Tenure': 24,\
        'MonthlyCharges': 75.5,\
        'TotalCharges': 1812.0,\
        # ... add all features\
    \}\
\
    result = predictor.predict(test_input)\
    print(f"Churn Probability: \{result['churn_probability']:.4f\}")\
    print("\\nTop Features:")\
    print(predictor.get_feature_importance())\
